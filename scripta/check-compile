#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
FABER_LIBRARY_HOME="${FABER_LIBRARY_HOME:-$ROOT/..}"

if [[ -n "${RADIX_ROOT:-}" ]]; then
  RADIX="$RADIX_ROOT"
elif [[ -d "$ROOT/../radix/crates/radix" ]]; then
  RADIX="$ROOT/../radix"
else
  RADIX="$ROOT/../../../radix"
fi

if [[ ! -d "$RADIX/crates/radix" ]]; then
  echo "check-compile: missing radix checkout at $RADIX" >&2
  exit 1
fi

if [[ -n "${FABER_ROOT:-}" ]]; then
  FABER="$FABER_ROOT"
elif [[ -f "$ROOT/../faber/Cargo.toml" ]]; then
  FABER="$ROOT/../faber"
else
  FABER="$ROOT/../../../faber"
fi

if [[ ! -f "$FABER/Cargo.toml" ]]; then
  echo "check-compile: missing faber checkout at $FABER" >&2
  exit 1
fi

RADIX_BIN="$RADIX/target/debug/radix"
if [[ ! -x "$RADIX_BIN" ]]; then
  (cd "$RADIX" && cargo build -q -p radix --bin radix)
fi

export FABER_LIBRARY_HOME
export RADIX_ROOT="$RADIX"

echo "check-compile: parsing src/triga.fab"
"$RADIX_BIN" check "$ROOT/src/triga.fab"

echo "check-compile: parsing src/geometry.fab"
"$RADIX_BIN" check "$ROOT/src/geometry.fab"

echo "check-compile: checking geometry attribute exemplar"
"$RADIX_BIN" check "$ROOT/exempla/triga-geometry-attributes.fab"

echo "check-compile: checking Stage 4 source-owned facts exemplar"
"$RADIX_BIN" check "$ROOT/exempla/triga-stage4-source-facts.fab"

echo "check-compile: checking Hello Voxel first-draw facts exemplar"
"$RADIX_BIN" check "$ROOT/exempla/hello-voxel-first-draw-facts.fab"

echo "check-compile: checking Hello Voxel shaders exemplar"
"$RADIX_BIN" check "$ROOT/exempla/triga-hello-voxel-shaders.fab"

echo "check-compile: checking Hello Voxel pipeline exemplar"
"$RADIX_BIN" check "$ROOT/exempla/triga-hello-voxel-pipeline.fab"

echo "check-compile: checking vertex-fragment stub"
"$RADIX_BIN" check "$ROOT/exempla/triga-vertex-fragment-stub.fab"

echo "check-compile: checking scene-store exemplar"
"$RADIX_BIN" check "$ROOT/exempla/triga-scene-store.fab"

echo "check-compile: checking scene-store exemplar through Faber provider path"
(cd "$ROOT" && cargo run -q --manifest-path "$FABER/Cargo.toml" -- check exempla/triga-scene-store.fab)

echo "check-compile: running scene-store generated-Rust acceptance"
(cd "$ROOT" && cargo run -q --manifest-path "$FABER/Cargo.toml" -- run --compile exempla/triga-scene-store.fab)

"$ROOT/scripta/check-transforms"
"$ROOT/scripta/check-exempla-inventory"
