#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RADIX="${RADIX_ROOT:-$ROOT/../radix}"
FABER_LIBRARY_HOME="${FABER_LIBRARY_HOME:-$ROOT/..}"

if [[ ! -d "$RADIX/crates/radix" ]]; then
  echo "check-compile: missing radix checkout at $RADIX" >&2
  exit 1
fi

RADIX_BIN="$RADIX/target/debug/radix"
if [[ ! -x "$RADIX_BIN" ]]; then
  (cd "$RADIX" && cargo build -q -p radix --bin radix)
fi

export FABER_LIBRARY_HOME

checked=0
while IFS= read -r file; do
  echo "check-compile: checking ${file#"$ROOT/"}"
  "$RADIX_BIN" check "$file"
  checked=$((checked + 1))
done < <(find "$ROOT/src" "$ROOT/exempla" -type f -name '*.fab' | LC_ALL=C sort)

if [[ "$checked" -eq 0 ]]; then
  echo "check-compile: no Faber sources found" >&2
  exit 1
fi

"$ROOT/scripta/check-transforms"
