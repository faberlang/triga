#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC="$ROOT/src"
status=0

if [[ ! -d "$SRC" ]]; then
  echo "check-source: missing src directory: $SRC" >&2
  exit 1
fi

while IFS= read -r -d '' file; do
  if grep -nE '^[[:space:]]*//' "$file"; then
    echo "check-source: line-start comments are not allowed in $file" >&2
    status=1
  fi

  if grep -nE '@[[:space:]]*(externa|subsidia)\b' "$file"; then
    echo "check-source: retired @ externa/@ subsidia annotation in $file" >&2
    status=1
  fi

  if grep -nE '\bad[[:space:]]+[A-Za-z_][A-Za-z0-9_]*[[:space:]]*\{' "$file"; then
    echo "check-source: route calls must use canonical string route syntax in $file" >&2
    status=1
  fi

  if grep -nE '∪[[:space:]]*nihil[[:space:]]+[A-Za-z_][A-Za-z0-9_]*[[:space:]]*=' "$file"; then
    echo "check-source: retired optional genus field syntax in $file; use sponte" >&2
    status=1
  fi
done < <(find "$SRC" -name '*.fab' -print0)

exit "$status"