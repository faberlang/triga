#!/usr/bin/env python3
"""Validate and report the Triga capability ledger without external tools."""

import argparse
import json
from pathlib import Path
import sys

ROOT = Path(__file__).resolve().parent.parent
LEDGER = ROOT / "proof" / "capabilities.json"
VALID_STATES = {"unsupported", "available", "passed", "failed"}


def load(path):
    with path.open(encoding="utf-8") as source:
        return json.load(source)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true", dest="as_json")
    args = parser.parse_args()
    errors = []
    ledger = load(LEDGER)
    levels = set(ledger["evidence_levels"])
    score = 0
    floor_results = []
    proof_ids = set()

    for domain in ledger["domains"]:
        points = sum(proof["points"] for proof in domain["proofs"])
        if points != domain["weight"]:
            errors.append(f"{domain['id']}: proof points {points} != weight {domain['weight']}")
        earned = 0
        for proof in domain["proofs"]:
            if proof["id"] in proof_ids:
                errors.append(f"duplicate proof id: {proof['id']}")
            proof_ids.add(proof["id"])
            if not proof.get("owner"):
                errors.append(f"{proof['id']}: missing owner")
            if proof["level"] not in levels:
                errors.append(f"{proof['id']}: unknown evidence level {proof['level']}")
            if proof["state"] not in VALID_STATES:
                errors.append(f"{proof['id']}: unknown state {proof['state']}")
            if proof["state"] == "passed":
                earned += proof["points"]
        score += earned
        floor_results.append({"domain": domain["id"], "earned": earned, "floor": domain["floor"], "met": earned >= domain["floor"]})

    total_weight = sum(domain["weight"] for domain in ledger["domains"])
    if total_weight != 100:
        errors.append(f"domain weights total {total_weight}, expected 100")

    capstones = []
    for capstone_id in ledger["capstones"]:
        path = ROOT / "proof" / "capstones" / f"{capstone_id}.json"
        if not path.exists():
            errors.append(f"missing capstone manifest: {path.relative_to(ROOT)}")
            continue
        manifest = load(path)
        if manifest.get("id") != capstone_id:
            errors.append(f"{capstone_id}: manifest id mismatch")
        if manifest.get("state") not in VALID_STATES:
            errors.append(f"{capstone_id}: invalid state")
        if manifest.get("required_level") not in levels:
            errors.append(f"{capstone_id}: invalid required evidence level")
        for field in ("workload", "fixtures", "expected", "reason"):
            if field not in manifest:
                errors.append(f"{capstone_id}: missing {field}")
        capstones.append({"id": capstone_id, "state": manifest.get("state"), "stale": path.stat().st_mtime < LEDGER.stat().st_mtime})
        if capstones[-1]["stale"]:
            errors.append(f"{capstone_id}: manifest is older than capability ledger")

    browser = {"available": False, "result": "unavailable", "reason": "Stage 0 has no direct WebGPU browser runner"}
    report = {"schema_version": 1, "score": score, "threshold": ledger["threshold"], "weights": total_weight, "floors": floor_results, "capstones": capstones, "browser": browser, "errors": errors}
    if args.as_json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"score: {score}/{total_weight} (threshold {ledger['threshold']})")
        print(f"mandatory floors: {sum(item['met'] for item in floor_results)}/{len(floor_results)} met")
        print(f"capstones: {len(capstones)}/{len(ledger['capstones'])} manifested; {sum(item['state'] == 'passed' for item in capstones)} passed")
        print(f"browser validation: {browser['result']} — {browser['reason']}")
        print(f"artifact freshness: {'ok' if not any(item['stale'] for item in capstones) else 'stale'}")
        for error in errors:
            print(f"error: {error}", file=sys.stderr)
    return 1 if errors else 0


if __name__ == "__main__":
    raise SystemExit(main())
